<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!-- Suppress known vulnerabilities that are being addressed -->
    
    <!-- Example: Suppress a specific CVE in a dependency -->
    <!--
    <suppress>
        <notes><![CDATA[
            This CVE is being tracked in issue #123 and will be fixed in next release
        ]]></notes>
        <cve>CVE-2023-1234</cve>
        <packageUrl regex="true">^pkg:maven/.*</packageUrl>
    </suppress>
    -->
    
    <!-- Suppress false positives for test dependencies -->
    <suppress>
        <notes><![CDATA[
            Test dependencies are not included in production builds
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/.*test.*</packageUrl>
        <cve></cve>
    </suppress>
    
    <!-- Suppress vulnerabilities in development tools -->
    <suppress>
        <notes><![CDATA[
            Development tools are not included in production builds
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/.*detekt.*</packageUrl>
        <cve></cve>
    </suppress>
    
    <!-- Suppress known low-severity issues -->
    <suppress>
        <notes><![CDATA[
            Low severity vulnerabilities that don't affect our usage
        ]]></notes>
        <cvssBelow>4.0</cvssBelow>
        <packageUrl regex="true">^pkg:maven/.*</packageUrl>
    </suppress>
</suppressions>
