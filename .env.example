# DrMindit Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to version control

# Supabase Configuration
SUPABASE_DEV_URL=https://your-dev-project.supabase.co
SUPABASE_DEV_ANON_KEY=your-dev-anon-key-here
SUPABASE_DEV_SERVICE_KEY=your-dev-service-key-here

SUPABASE_STAGING_URL=https://your-staging-project.supabase.co
SUPABASE_STAGING_ANON_KEY=your-staging-anon-key-here
SUPABASE_STAGING_SERVICE_KEY=your-staging-service-key-here

SUPABASE_PROD_URL=https://your-prod-project.supabase.co
SUPABASE_PROD_ANON_KEY=your-prod-anon-key-here
SUPABASE_PROD_SERVICE_KEY=your-prod-service-key-here

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_WEB_CLIENT_ID=your-web-client-id
FIREBASE_ANDROID_CLIENT_ID=your-android-client-id

# API Keys
API_KEY=your-api-key-here
JWT_SECRET=your-jwt-secret-here

# External Services
SENTRY_DSN=your-sentry-dsn-here
ANALYTICS_KEY=your-analytics-key-here
PUSH_NOTIFICATIONS_KEY=your-push-notifications-key-here

# Build Configuration
RELEASE_STORE_FILE=release.keystore
RELEASE_STORE_PASSWORD=your-keystore-password
RELEASE_KEY_ALIAS=your-key-alias
RELEASE_KEY_PASSWORD=your-key-password

# Feature Flags
FEATURE_CRISIS_DETECTION=true
FEATURE_ANALYTICS=true
FEATURE_PUSH_NOTIFICATIONS=true

# Environment
APP_ENV=development
APP_VERSION=1.0.0
BUILD_NUMBER=1
