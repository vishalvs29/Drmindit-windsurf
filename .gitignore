# DrMindit Git Ignore - Security Focused (Less Restrictive)

# Environment and secrets (CRITICAL - NEVER COMMIT)
.env
.env.local
.env.production
.env.staging
.env.development
*.env

# Firebase configuration (CRITICAL - NEVER COMMIT)
google-services.json
firebase.json
google-services.json.example

